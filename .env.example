# ablefy-mcp configuration.
# Slice 1 runs entirely on fakes — every real value below is filled in a later slice.
# Copy to `.env` for local overrides (`.env` is gitignored). Claude Desktop passes
# these via the `env` block in claude_desktop_config.json (see README).

# --- ablefy backend (slice 2: real local Rails BE; faked until then) ---
ABLEFY_API_BASE=http://localhost:3000
ABLEFY_SELLER_TOKEN=
COACH_PRODUCT_SLUG=the-systems-studio
COACH_PRODUCT_FORM=membership          # the coach is a membership product → flat grant writes a real MembershipSession
ABLEFY_RAILS_CONTAINER=elopage-rails-app-1   # docker container the flat grant shells into (rails runner)

# --- pricing / meter (the MCP owns the meter + cap) ---
PRICE_PER_Q=0.10
MONTHLY_CAP=9.00
CURRENCY=EUR

# --- payment rail (slice 3: real Algorand testnet; "mock" by default) ---
PAYMENT_RAIL=mock                                    # mock | algorand
ALGOD_URL=https://testnet-api.algonode.cloud         # AlgoNode testnet (no token needed)
ALGOD_TOKEN=
BUYER_WALLET_MNEMONIC=                               # 25-word mnemonic of a FUNDED testnet wallet
CREATOR_ADDRESS=                                     # the creator's receiving address
ALGO_MICROALGOS_PER_Q=1000                           # on-chain amount per question (0.001 ALGO)
# Generate wallets: `npm run wallet:new` (×2 — fund the buyer at a testnet faucet)

# --- coach LLM (slice 4) ---
COACH_LLM=fake                 # fake | anthropic | litellm
ANTHROPIC_API_KEY=             # for COACH_LLM=anthropic (direct Anthropic API key)
LLM_BASE_URL=                  # for COACH_LLM=litellm, e.g. http://localhost:4000/v1
LLM_API_KEY=                   # LiteLLM proxy key, if it requires one
COACH_MODEL=claude-haiku-4-5-20251001   # anthropic: a model id · litellm: your proxy's model alias

# --- earnings bridge (this repo = emitter; elopage console consumes later) ---
EARNINGS_FILE=~/.ablefy-mcp/earnings.json
# FLAT_ACCESS_FILE=~/.ablefy-mcp/flat-access.json   # write-through cache of real flat grants (default shown)
